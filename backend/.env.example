# Helix Backend Configuration Environment Variables Template

# 1. Database Configuration
# Production database connection URL.
# Example: postgresql://username:password@neon-database-host:5432/helix?sslmode=require
DATABASE_URL=postgresql://postgres:password@localhost:5432/helix

# 2. LLM Provider Configuration
LLM_PROVIDER=gemini
# Your Gemini API Key from Google AI Studio
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
# Model configuration
GEMINI_MODEL=gemini-2.5-flash

# 3. Security & Allowed Origins
# The production URL of the Next.js frontend to allow CORS requests.
# Example: https://helix-frontend.vercel.app
FRONTEND_URL=http://localhost:3000

# 4. Git Ingestion Storage Root Path
# Configures the absolute or relative directory path where repository clones are stored.
# If left blank, it defaults to the standard './storage/repositories' path.
REPOSITORY_STORAGE_PATH=

# 5. GitHub API Authentication (Optional)
# Recommended to increase rate limits when checking and synchronizing code repositories.
GITHUB_TOKEN=
